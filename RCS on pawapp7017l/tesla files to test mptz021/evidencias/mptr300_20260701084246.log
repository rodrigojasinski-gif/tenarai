    sort -T ${RACE}/tmp -k1.1,1.1 -k1.7,1.31 -k1.32,1.56 -k1.57,1.71r -k1.88,1.167r -o ${REFORMAT_SORTOUT} ${SORTIN_BOTH2}      
  fi


